{
  "name": "snipcommand",
  "version": "0.2.6",
  "description": "A free and open source command snippets manager for organize and copy fast.",
  "private": true,
  "main": "public/electron.js",
  "license": "MIT",
  "homepage": "./",
  "dependencies": {
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^9.3.2",
    "@testing-library/user-event": "^7.1.2",
    "electron-is-dev": "^1.2.0",
    "electron-store": "^6.0.0",
    "electron-updater": "^6.8.3",
    "generate-password": "^1.5.1",
    "lowdb": "^1.0.0",
    "markdown-it": "^11.0.0",
    "noty": "^3.2.0-beta",
    "prop-types": "^15.7.2",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-markdown-editor-lite": "^1.2.2",
    "react-redux": "^7.2.0",
    "react-scripts": "3.4.1",
    "redux": "^4.0.5",
    "redux-thunk": "^2.3.0",
    "sass": "1.77.8",
    "shortid": "^2.2.15"
  },
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider rescripts start",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider rescripts build",
    "test": "rescripts test",
    "eject": "react-scripts eject",
    "electron-dev": "concurrently \"cross-env BROWSER=none yarn start\" \"wait-on http://localhost:3000 && electron .\"",
    "release": "cross-env NODE_OPTIONS=--openssl-legacy-provider rescripts build && electron-builder --win --publish always && node scripts/clean-release-assets.js"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@rescripts/cli": "^0.0.14",
    "@rescripts/rescript-env": "^0.0.12",
    "concurrently": "^5.2.0",
    "cross-env": "^7.0.2",
    "electron": "^9.1.0",
    "electron-builder": "^22.7.0",
    "wait-on": "^5.1.0"
  },
  "keywords": [
    "command",
    "snippet",
    "copy",
    "clipboard",
    "snippets",
    "snippets-manager",
    "macos",
    "windows",
    "linux",
    "react",
    "productivity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Tommylulu886943/SnipCommand.git"
  },
  "bugs": {
    "url": "https://github.com/Tommylulu886943/SnipCommand/issues"
  },
  "author": {
    "name": "Tommy Lu",
    "url": "https://github.com/Tommylulu886943",
    "email": "jkruby886743@gmail.com"
  },
  "originalAuthor": {
    "name": "Güray Yarar (gurayyarar)",
    "url": "https://github.com/gurayyarar",
    "email": "guray.yarar@gmail.com"
  },
  "links": {
    "project-page": "https://github.com/Tommylulu886943/SnipCommand",
    "author-page": "https://github.com/Tommylulu886943",
    "original-author-page": "https://github.com/gurayyarar",
    "license": "https://github.com/Tommylulu886943/SnipCommand/blob/master/LICENSE",
    "changelogs": "https://github.com/Tommylulu886943/SnipCommand/blob/master/documentation/CHANGELOGS.md",
    "documentation": "https://github.com/Tommylulu886943/SnipCommand/blob/master/documentation/DOCUMENTATION.md",
    "issues": "https://github.com/Tommylulu886943/SnipCommand/issues",
    "releases": "https://github.com/Tommylulu886943/SnipCommand/releases"
  },
  "build": {
    "productName": "SnipCommand",
    "appId": "com.snipcommand.app",
    "publish": {
      "provider": "github",
      "owner": "Tommylulu886943",
      "repo": "SnipCommand",
      "releaseType": "release"
    },
    "directories": {
      "output": "app"
    },
    "files": [
      "build/**/*"
    ],
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "mac": {
      "icon": "public/images/app.icns"
    },
    "win": {
      "icon": "public/images/app.ico"
    },
    "linux": {
      "icon": "public/images/logo/snip_command.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
